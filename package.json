{
  "name": "pup-recorder",
  "version": "0.4.9",
  "description": "Record web pages as video",
  "repository": {
    "type": "git",
    "url": "https://github.com/Autokaka/pup-recorder.git"
  },
  "license": "MIT",
  "author": {
    "name": "autokaka",
    "email": "qq1909698494@gmail.com"
  },
  "type": "module",
  "bin": {
    "pup": "dist/cli.js"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">= 1",
    "node": ">= 22"
  },
  "engineStrict": true,
  "trustedDependencies": [
    "@seydx/node-av-darwin-arm64",
    "@seydx/node-av-darwin-x64",
    "@seydx/node-av-linux-arm64",
    "@seydx/node-av-linux-x64",
    "@seydx/node-av-win32-arm64-mingw",
    "@seydx/node-av-win32-arm64-msvc",
    "@seydx/node-av-win32-x64-mingw",
    "@seydx/node-av-win32-x64-msvc",
    "electron"
  ],
  "optionalDependencies": {
    "@seydx/node-av-darwin-arm64": "6.0.0",
    "@seydx/node-av-darwin-x64": "6.0.0",
    "@seydx/node-av-linux-arm64": "6.0.0",
    "@seydx/node-av-linux-x64": "6.0.0",
    "@seydx/node-av-win32-arm64-mingw": "6.0.0",
    "@seydx/node-av-win32-arm64-msvc": "6.0.0",
    "@seydx/node-av-win32-x64-mingw": "6.0.0",
    "@seydx/node-av-win32-x64-msvc": "6.0.0"
  },
  "dependencies": {
    "commander": "latest",
    "electron": "latest",
    "fflate": "latest",
    "node-av": "6.0.0",
    "tree-kill": "latest",
    "source-map-support": "latest",
    "systeminformation": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@microsoft/api-extractor": "latest",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "latest",
    "tsup": "latest"
  },
  "scripts": {
    "build": "bun build.ts",
    "pup": "bun src/cli.ts"
  }
}
