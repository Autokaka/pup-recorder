{
  "name": "pup-recorder",
  "version": "0.2.7",
  "description": "Record web pages as video",
  "repository": {
    "type": "git",
    "url": "https://github.com/Autokaka/pup-recorder.git"
  },
  "license": "MIT",
  "author": {
    "name": "autokaka",
    "email": "qq1909698494@gmail.com"
  },
  "type": "module",
  "bin": {
    "pup": "dist/cli.js"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">= 1",
    "node": ">= 20"
  },
  "engineStrict": true,
  "dependencies": {
    "commander": "latest",
    "electron": "latest",
    "fflate": "latest",
    "node-av": "latest",
    "tree-kill": "latest",
    "source-map-support": "latest",
    "systeminformation": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "latest",
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "@typescript/native-preview": "latest",
    "tsup": "latest"
  },
  "scripts": {
    "build": "bun build.ts",
    "pup": "bun src/cli.ts"
  }
}
